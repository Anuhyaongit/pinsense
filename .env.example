# Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://pinsense_user:pinsense_secure_pass_change_me@db:5432/pinsense_db

# Environment
ENV=development
DEBUG=True

# Frontend
REACT_APP_API_URL=http://localhost:8000

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your_github_username/pinsense

# Deployment
DEPLOY_SERVER=deploy@your-server.com
DEPLOY_PATH=/app/pinsense

# Security (change these!)
SECRET_KEY=your_secret_key_here_change_this
API_KEY=your_api_key_here_change_this
